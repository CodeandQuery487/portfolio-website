
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Nimra Tabassum | Web Developer & Software Student</title>
  <!-- Google Fonts + Font Awesome -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background-color: #0d0d0d;
      color: #eef2ff;
      scroll-behavior: smooth;
    }

    /* Purple accent color */
    :root {
      --accent: #6C63FF;
      --accent-dark: #5a52e0;
      --accent-glow: rgba(108, 99, 255, 0.3);
      --glass-bg: rgba(30, 30, 46, 0.7);
      --glass-border: rgba(108, 99, 255, 0.2);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.8rem;
    }

    /* Scroll animations */
    section {
      padding: 5rem 0;
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Glassmorphism base */
    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      transition: all 0.3s ease;
    }

    .glass-card:hover {
      border-color: var(--accent);
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(108, 99, 255, 0.15);
    }

    /* Navbar */
    .navbar {
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 1000;
      padding: 1.2rem 0;
      background: rgba(13, 13, 13, 0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(108, 99, 255, 0.2);
    }

    .nav-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }

    .logo {
      font-size: 1.7rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--accent), #b084ff);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    .nav-links {
      display: flex;
      gap: 2.2rem;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: #cbd5e6;
      transition: color 0.2s;
      font-size: 1rem;
    }

    .nav-links a:hover {
      color: var(--accent);
    }

    .menu-toggle {
      display: none;
      font-size: 1.6rem;
      background: none;
      border: none;
      color: #fff;
      cursor: pointer;
    }

    /* Buttons */
    .btn {
      display: inline-block;
      padding: 0.8rem 2rem;
      border-radius: 40px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.25s ease;
      border: none;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
    }

    .btn-primary {
      background: var(--accent);
      color: white;
      box-shadow: 0 8px 20px var(--accent-glow);
    }

    .btn-primary:hover {
      background: var(--accent-dark);
      transform: translateY(-3px);
    }

    .btn-outline {
      border: 2px solid var(--accent);
      background: transparent;
      color: var(--accent);
    }

    .btn-outline:hover {
      background: var(--accent);
      color: white;
      transform: translateY(-3px);
    }

    /* Hero Section */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding-top: 5rem;
    }

    .hero-grid {
      display: flex;
      align-items: center;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .hero-content {
      flex: 1.3;
    }

    .hero-badge {
      background: rgba(108, 99, 255, 0.15);
      display: inline-block;
      padding: 0.3rem 1.2rem;
      border-radius: 40px;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      color: var(--accent);
    }

    .hero-content h1 {
      font-size: 3.5rem;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-title {
      font-size: 1.4rem;
      font-weight: 500;
      margin-bottom: 0.8rem;
      color: #b9c3e6;
    }

    .hero-desc {
      margin: 1.5rem 0 2rem;
      max-width: 500px;
      opacity: 0.85;
      line-height: 1.6;
    }

    .btn-group {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .hero-image {
      flex: 1;
      text-align: center;
    }

    .avatar {
      width: 280px;
      height: 280px;
      background: linear-gradient(135deg, var(--accent), #8f88ff);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 7rem;
      box-shadow: 0 25px 40px rgba(108, 99, 255, 0.3);
      border: 3px solid rgba(108, 99, 255, 0.5);
    }

    /* Section Titles */
    .section-title {
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 2.5rem;
      position: relative;
      display: inline-block;
    }

    .section-title:after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 0;
      width: 60%;
      height: 4px;
      background: var(--accent);
      border-radius: 4px;
    }

    /* About Section */
    .about-grid {
      display: flex;
      gap: 2.5rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .about-text {
      flex: 1.5;
      font-size: 1rem;
      line-height: 1.7;
    }

    .about-text p {
      margin-bottom: 1rem;
      opacity: 0.9;
    }

    .about-photo {
      flex: 1;
      text-align: center;
    }

    .profile-circle {
      width: 220px;
      height: 220px;
      background: linear-gradient(145deg, #1e1e30, #12121f);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 3px solid var(--accent);
      box-shadow: 0 20px 30px rgba(0, 0, 0, 0.3);
    }

    .profile-circle i {
      font-size: 5.5rem;
      color: var(--accent);
    }

    /* Skills Section */
    .skills-container {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .skill-category {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      border-radius: 28px;
      padding: 1.8rem;
      border: 1px solid var(--glass-border);
    }

    .category-title {
      font-size: 1.4rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      color: var(--accent);
    }

    .skill-item {
      margin-bottom: 1.2rem;
    }

    .skill-info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .skill-bar-bg {
      background: #2a2a3a;
      border-radius: 20px;
      height: 8px;
      overflow: hidden;
    }

    .skill-bar-fill {
      background: var(--accent);
      width: 0%;
      height: 100%;
      border-radius: 20px;
      transition: width 1s ease-out;
    }

    /* Projects Grid */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 1rem;
    }

    .project-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      padding: 1.5rem;
      transition: all 0.3s ease;
    }

    .project-card:hover {
      transform: translateY(-6px);
      border-color: var(--accent);
    }

    .project-title {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .project-desc {
      opacity: 0.8;
      margin: 0.8rem 0;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .tech-badge {
      display: inline-block;
      background: rgba(108, 99, 255, 0.2);
      padding: 0.25rem 0.8rem;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 500;
      margin: 0.5rem 0.5rem 0 0;
    }

    .project-link {
      display: inline-block;
      margin-top: 1.2rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .project-link i {
      margin-left: 5px;
      transition: transform 0.2s;
    }

    .project-link:hover i {
      transform: translateX(5px);
    }

    /* Contact Section */
    .contact-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      border-radius: 28px;
      padding: 2.5rem;
      text-align: center;
      border: 1px solid var(--glass-border);
    }

    .contact-icon {
      font-size: 3rem;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    .social-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: var(--accent);
      color: white;
      padding: 1rem 2rem;
      border-radius: 50px;
      text-decoration: none;
      font-weight: 600;
      margin-top: 1.5rem;
      transition: all 0.25s;
    }

    .social-btn:hover {
      background: var(--accent-dark);
      transform: scale(1.03);
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 2rem;
      border-top: 1px solid rgba(108, 99, 255, 0.2);
      margin-top: 2rem;
      font-size: 0.85rem;
      opacity: 0.7;
    }

    /* Responsive */
    @media (max-width: 850px) {
      .nav-links {
        display: none;
        flex-direction: column;
        width: 100%;
        text-align: center;
        padding: 1rem 0;
        gap: 1rem;
      }
      .nav-links.show {
        display: flex;
      }
      .menu-toggle {
        display: block;
      }
      .nav-container {
        flex-wrap: wrap;
      }
      .hero-content h1 {
        font-size: 2.5rem;
      }
      .avatar {
        width: 200px;
        height: 200px;
        font-size: 5rem;
      }
      .section-title {
        font-size: 1.8rem;
      }
      section {
        padding: 3rem 0;
      }
    }

    @media (max-width: 480px) {
      .container {
        padding: 0 1.2rem;
      }
      .btn-group {
        flex-direction: column;
        align-items: stretch;
      }
      .btn {
        text-align: center;
      }
    }
  </style>
</head>
